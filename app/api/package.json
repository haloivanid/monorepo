  "scripts": {
    "build": "nest build",
    "format": "../../node_modules/prettier/bin/prettier.cjs --config ../../.prettierrc.json --write \"**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "dev": "nest start --watch",
    "jest": "TS_NODE_PROJECT=tsconfig.json node -r ts-node/register -r tsconfig-paths/register /node_modules/jest/bin/jest.js",
    "test:unit": "pnpm jest --coverage --config ./test/jest.config.ts",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "test": "concurrently -p \"[{name}]\" -n \"UNT,E2E\" \"pnpm test:unit\" \"pnpm test:e2e\""
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
